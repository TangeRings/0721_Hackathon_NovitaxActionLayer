# Server-side Novita AI key used by Next.js API routes in `app/api/*` (see lib/novita.ts).
# Get your key at https://novita.ai/settings/key-management
NOVITA_API_KEY="YOUR_NOVITA_API_KEY"

# Novita model ID to use for JSON reasoning tasks. Format: provider/model-name
NOVITA_MODEL="deepseek/deepseek-v4-flash"

# Optional public app URL for client-side usage.
# Prefix with NEXT_PUBLIC_ only for values safe to expose in browser bundles.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Server-side ActionLayer key used by app/api/actionlayer/* routes (see lib/actionlayer.ts).
ACTIONLAYER_API_KEY="YOUR_ACTIONLAYER_API_KEY"
ACTIONLAYER_API_URL="https://api.actionlayer.io"
